{  
  // ==============================
  // 🎨 Appearance & UI
  // ==============================
  "theme": "Nightfox - opaque",
  "icon_theme": "Material Icon Theme",
  "ui_font_size": 16.0,
  "buffer_font_size": 20.0,
  "buffer_font_weight": 500.0,
  "cursor_shape": "bar",
  "minimap": {
    "show": "never",
  },

  // ==============================
  // 🤖 AI / Agent Settings
  // ==============================
  "disable_ai": true,

  // ==============================
  // 🧠 Editor Behavior
  // ==============================
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "colorize_brackets": true,
  "auto_signature_help": true,
  "show_signature_help_after_edits": true,
  "hover_popover_enabled": true,
  "inlay_hints": {
    "enabled": false,
  },

  // ==============================
  // ✍️ Formatting & Code Style
  // ==============================
  "prettier": {
    "allowed": false,
  },

  // ==============================
  // 🔒 Privacy & Telemetry
  // ==============================
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // ==============================
  // 🎨 Extensions
  // To find currently installed extensions: `ls ~/.local/share/zed/extensions/installed`
  // ==============================
  "auto_install_extensions": {
    "material-icon-theme": true,
    "nvim-nightfox": true,
    "rainbow-csv": true,
    "emmet": true,
  },
}

